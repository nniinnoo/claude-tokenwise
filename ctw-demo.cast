[0.052, "o", "    \u001b[33m\u001b[34mdef\u001b[39m\u001b[33m celsius_to_fahrenheit(celsius: \u001b[36mfloat\u001b[39m\u001b[33m) -> \u001b[36mfloat\u001b[39m\u001b[33m:\u001b[39m\r\n        \u001b[31m\"\"\"Convert Celsius to Fahrenheit. Formula: (C × 9/5) + 32\"\"\"\u001b[39m\r\n        \u001b[34mreturn\u001b[39m celsius * \u001b[32m9\u001b[39m / \u001b[32m5\u001b[39m + \u001b[32m32\u001b[39m\r\n    \r\n    \u001b[33m\u001b[34mdef\u001b[39m\u001b[33m fahrenheit_to_celsius(fahrenheit: \u001b[36mfloat\u001b[39m\u001b[33m) -> \u001b[36mfloat\u001b[39m\u001b[33m:\u001b[39m\r\n        \u001b[31m\"\"\"Convert Fahrenheit to Celsius. Formula: (F - 32) × 5/9\"\"\"\u001b[39m\r\n        \u001b[34mreturn\u001b[39m (fahrenheit - \u001b[32m32\u001b[39m) * \u001b[32m5\u001b[39m / \u001b[32m9\u001b[39m\r\n\r\n\u001b[0m\u001b[1m\u001b[37mEdge cases considered:\u001b[39m\u001b[22m\u001b[0m\r\n\r\n    * \u001b[0mAbsolute zero: -273.15°C = -459.67°F (physically valid lower bound)\u001b[0m\r\n    * \u001b[0m0°C = 32°F, 100°C = 212°F (standard reference points)\u001b[0m\r\n    * \u001b[0mFloats handled natively; no integer truncation issues\u001b[0m\r\n    * \u001b[0mNo input validation added (not requested) — caller is responsible for numeric input\u001b[0m\r\n\r\n\u001b[0m\u001b[1m\u001b[37mVerification:\u001b[39m\u001b[22m\u001b[0m\r\n\r\n\u001b[0m\u001b[90m┌───────\u001b[39m\u001b[9"]
[0.000, "o", "0m┬──────────\u001b[39m\u001b[90m┬──────────────────────┐\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m│\u001b[39m\u001b[31m Input \u001b[39m\u001b[90m│\u001b[39m\u001b[31m Expected \u001b[39m\u001b[90m│\u001b[39m\u001b[31m Formula check        \u001b[39m\u001b[90m│\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m├───────\u001b[39m\u001b[90m┼──────────\u001b[39m\u001b[90m┼──────────────────────┤\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m│\u001b[39m 0°C   \u001b[90m│\u001b[39m 32°F     \u001b[90m│\u001b[39m 0×9/5+32 = 32 ✓      \u001b[90m│\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m├───────\u001b[39m\u001b[90m┼──────────\u001b[39m\u001b[90m┼──────────────────────┤\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m│\u001b[39m 100°C \u001b[90m│\u001b[39m 212°F    \u001b[90m│\u001b[39m 100×9/5+32 = 212 ✓   \u001b[90m│\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m├───────\u001b[39m\u001b[90m┼──────────\u001b[39m\u001b[90m┼──────────────────────┤\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m│\u001b[39m 32°F  \u001b[90m│\u001b[39m 0°C   "]
[0.000, "o", "   \u001b[90m│\u001b[39m (32-32)×5/9 = 0 ✓    \u001b[90m│\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m├───────\u001b[39m\u001b[90m┼──────────\u001b[39m\u001b[90m┼──────────────────────┤\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m│\u001b[39m 212°F \u001b[90m│\u001b[39m 100°C    \u001b[90m│\u001b[39m (212-32)×5/9 = 100 ✓ \u001b[90m│\u001b[39m\u001b[0m\r\n\u001b[0m\u001b[90m└───────\u001b[39m\u001b[90m┴──────────\u001b[39m\u001b[90m┴──────────────────────┘\u001b[39m\u001b[0m\r\n\r\n\r\n"]
